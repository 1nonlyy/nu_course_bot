# Copy to .env and set real values. Do not commit .env.

BOT_TOKEN=your_bot_token_here
# production (default): JSON logs to stdout. dev: human-readable console logs
ENV=production
# Optional error reporting; leave empty to disable
SENTRY_DSN=
POLL_INTERVAL_MINUTES=5
DATABASE_URL=sqlite+aiosqlite:///./data/nu_bot.db
LOG_LEVEL=INFO
CATALOG_BASE_URL=https://registrar.nu.edu.kz
# 824 = Summer 2026 (see catalog semester dropdown)
CATALOG_TERM_ID=824
# When true, skip TLS certificate verification for the registrar (default true)
CATALOG_IGNORE_TLS_ERRORS=true
# Minimum seconds between scrapes of the same course (per process), default 180
# SCRAPE_MIN_INTERVAL_SECONDS=180
# Max active course subscriptions per Telegram user (default 10)
# MAX_SUBSCRIPTIONS_PER_USER=10
# Min seconds between /check per user; in-memory, single process only (default 30)
# CHECK_RATE_LIMIT_SECONDS=30
